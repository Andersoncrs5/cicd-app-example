pipeline {
    agent {
        kubernetes {
            yamlFile 'node-cicd-app/k8s/setup.yaml'
            defaultContainer 'node'
        }
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install & Test') {
            steps {
                dir('node-cicd-app') {
                    container('node') {
                        sh 'npm ci'
                        sh 'npm test'
                    }
                }
            }
        }

        stage('Check Branch') {
            steps {
                echo "Branch atual: ${env.GIT_BRANCH}"
            }
        }

        stage('Debug Envs') {
            steps {
                echo "Branch atual via env: ${env.BRANCH_NAME}"
                
                sh 'printenv | sort'
            }
        }

        stage('Build Image') {
            
            steps {
                container('kaniko') {
                    sh """
                    /kaniko/executor \
                    --context ${WORKSPACE}/node-cicd-app \
                    --dockerfile ${WORKSPACE}/node-cicd-app/Dockerfile \
                    --destination andersoncrms/node-cicd-app:${env.BUILD_NUMBER} \
                    --destination andersoncrms/node-cicd-app:latest
                    """
                }
            }
        }
    }
    post {
        success {
            echo '✅ Pipeline executado com sucesso!'
        }

        failure {
            echo '❌ Pipeline falhou! Verifique os logs.'
        }

        always {
            script {
                if (currentBuild.currentResult == 'SUCCESS') {
                    echo "🎉 Deploy concluído"
                } else {
                    echo "⚠️ Algo deu errado"
                }
            }
        }
    }
}